                  "sampleData": {},
                  "sourceCode": {
                    "code": "export const code = async (inputs) => {\n  // NOTE: unlike the generic HTTP piece (which nests under .response),\n  // the Airtable piece's custom_api_call returns {status, headers, body} directly.\n  const records = inputs.csmResponse?.body?.records || [];\n  const csmWorkloads = records.map(r => ({\n    recordId: r.id,\n    email: r.fields.Email,\n    name: r.fields.Name,\n    openOnboardings: r.fields['Open Onboardings'] || 0,\n  }));\n\n  if (csmWorkloads.length === 0) {\n    throw new Error('No active CSMs found — cannot assign onboarding.');\n  }\n\n  // Find whoever currently has the fewest open onboardings.\n  const sorted = [...csmWorkloads].sort((a, b) => a.openOnboardings - b.openOnboardings);\n  const assigned = sorted[0];\n\n  return {\n    assignedCsmEmail: assigned.email,\n    assignedCsmName: assigned.name,\n    assignedCsmRecordId: assigned.recordId,\n    newOpenCount: assigned.openOnboardings + 1,\n  };\n};",
                    "packageJson": "{}"
