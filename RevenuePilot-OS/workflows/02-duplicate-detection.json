              "sourceCode": {
                "code": "export const code = async (inputs) => {\n  const { lead, existing } = inputs;\n\n  // airtable_find_record returns an array: [] when no match, [{id, fields}, ...] when found\n  const found = Array.isArray(existing) && existing.length > 0 ? existing[0] : null;\n\n  if (!found) {\n    return {\n      action: 'create',\n      recordId: null,\n      mergedFields: {\n        Email: lead.email,\n        Phone: lead.phone,\n        'Full Name': lead.fullName,\n        Company: lead.company,\n        Source: lead.source,\n        Status: 'New',\n        'Created At': lead.capturedAt,\n        Duplicate: false,\n        Notes: `${lead.capturedAt} — created via ${lead.source}`,\n      },\n    };\n  }\n\n  const existingFields = found.fields || {};\n  const priorNotes = existingFields.Notes || '';\n  const touchLine = `${lead.capturedAt} — resubmitted via ${lead.source}`;\n\n  return {\n    action: 'update',\n    recordId: found.id,\n    mergedFields: {\n      Email: lead.email ?? existingFields.Email,\n      Phone: lead.phone ?? existingFields.Phone,\n      'Full Name': lead.fullName ?? existingFields['Full Name'],\n      Company: lead.company ?? existingFields.Company,\n      Duplicate: true,\n      Notes: priorNotes ? `${priorNotes}\\n${touchLine}` : touchLine,\n    },\n  };\n};",
                "packageJson": "{}"
              },
              "errorHandlingOptions": {
                "retryOnFailure": {
                  "value": false
                },
                "continueOnFailure": {
                  "value": false
                }
