                "sourceCode": {
                  "code": "// Normalizes whichever provider (Hunter / Apollo / Clearbit / generic) into one internal shape.\n// Swap the field paths below once a real vendor is wired in — this is a best-guess generic shape.\nfunction normalizeProviderResponse(raw) {\n  if (!raw) return null;\n  return {\n    companySize: raw.metrics?.employees ?? raw.company_size ?? null,\n    industry: raw.category?.industry ?? raw.industry ?? null,\n    country: raw.geo?.country ?? raw.location ?? null,\n  };\n}\n\nexport const code = async (inputs) => {\n  const { crmRecord, httpResponse } = inputs;\n  // The HTTP piece nests the real response under `.response` (status/body), not flat.\n  const status = httpResponse?.response?.status;\n  const body = httpResponse?.response?.body;\n  const ok = typeof status === 'number' && status >= 200 && status < 300;\n  const enrichment = ok ? normalizeProviderResponse(body) : null;\n\n  if (!enrichment) {\n    return {\n      success: false,\n      recordId: crmRecord.id,\n      fields: {\n        'Enrichment Incomplete': true,\n      },\n    };\n  }\n\n  return {\n    success: true,\n    recordId: crmRecord.id,\n    fields: {\n      'Company Size': enrichment.companySize ?? crmRecord.fields?.['Company Size'] ?? null,\n      Industry: enrichment.industry ?? crmRecord.fields?.Industry ?? null,\n      Country: enrichment.country ?? crmRecord.fields?.Country ?? null,\n      'Enrichment Incomplete': false,\n    },\n  };\n};",
                  "packageJson": "{}"
