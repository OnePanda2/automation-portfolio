              "code": "export const code = async (inputs) => {\n  const { crmRecord } = inputs;\n  const email = crmRecord?.fields?.Email || '';\n  const domain = email.includes('@') ? email.split('@')[1].toLowerCase().trim() : null;\n  return { crmRecord, domain };\n};",
