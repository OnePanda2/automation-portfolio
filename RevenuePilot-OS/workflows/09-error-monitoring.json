              "code": "export const code = async (inputs) => {\n  const body = inputs.body || {};\n  const { flowName, stepName, error, payload, retryCount } = body;\n\n  const errObj = error || {};\n  const RETRYABLE_STATUS = [429, 500, 502, 503, 504];\n  const retryable = errObj.name === 'TimeoutError' || RETRYABLE_STATUS.includes(errObj.status);\n  const rc = typeof retryCount === 'number' ? retryCount : 0;\n  const escalate = !retryable || rc >= 3;\n\n  return {\n    flowName: flowName || 'unknown',\n    stepName: stepName || 'unknown',\n    errorMessage: errObj.message || String(errObj) || 'Unknown error',\n    payloadJson: JSON.stringify(payload || {}),\n    retryCount: rc,\n    createdAtIso: new Date().toISOString(),\n    retryable,\n    escalate\n  };\n};",
              "packageJson": "{}"
            },
            "errorHandlingOptions": {
              "retryOnFailure": {
                "value": false
              },
              "continueOnFailure": {
                "value": false
              }
            }
