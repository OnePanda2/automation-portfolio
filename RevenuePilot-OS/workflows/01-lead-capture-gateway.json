            "sourceCode": {
              "code": "const DISPOSABLE_DOMAINS = new Set([\n  'mailinator.com', 'guerrillamail.com', 'tempmail.com', '10minutemail.com'\n]);\n\nfunction detectSource(body) {\n  if (body?.form_response?.answers) return 'typeform';\n  if (body?.data && body?.eventId) return 'tally';\n  if (body?.properties && body?.objectId) return 'hubspot';\n  if (body?.source === 'manual') return 'manual';\n  return 'website';\n}\n\nfunction extractTypeform(body) {\n  const answers = body.form_response.answers || [];\n  const get = (ref) => answers.find(a => a.field?.ref === ref);\n  return {\n    email: get('email')?.email ?? null,\n    phone: get('phone')?.phone_number ?? null,\n    fullName: get('name')?.text ?? null,\n    company: get('company')?.text ?? null,\n  };\n}\n\nfunction extractHubSpot(body) {\n  const p = body.properties || {};\n  return {\n    email: p.email?.value ?? null,\n    phone: p.phone?.value ?? null,\n    fullName: p.full_name?.value ?? null,\n    company: p.company?.value ?? null,\n  };\n}\n\nfunction extractFlat(body) {\n  return {\n    email: body.email ?? null,\n    phone: body.phone ?? null,\n    fullName: body.name ?? body.full_name ?? null,\n    company: body.company ?? null,\n  };\n}\n\nfunction isValidEmail(email) {\n  if (!email) return false;\n  const regex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  if (!regex.test(email)) return false;\n  const domain = email.split('@')[1]?.toLowerCase();\n  return !DISPOSABLE_DOMAINS.has(domain);\n}\n\nfunction isValidPhone(phone) {\n  if (!phone) return true;\n  const digits = phone.replace(/\\D/g, '');\n  return digits.length >= 7 && digits.length <= 15;\n}\n\nexport const code = async (inputs) => {\n  const webhookBody = inputs.webhookBody || {};\n  const source = detectSource(webhookBody);\n\n  let extracted;\n  switch (source) {\n    case 'typeform': extracted = extractTypeform(webhookBody); break;\n    case 'hubspot':  extracted = extractHubSpot(webhookBody); break;\n    default:         extracted = extractFlat(webhookBody); break;\n  }\n\n  const lead = {\n    email: extracted.email?.trim().toLowerCase() ?? null,\n    phone: extracted.phone?.trim() ?? null,\n    fullName: extracted.fullName?.trim() ?? null,\n    company: extracted.company?.trim() ?? null,\n    source,\n    capturedAt: new Date().toISOString(),\n  };\n\n  if (!isValidEmail(lead.email)) {\n    return { valid: false, lead: null, rejectionReason: 'invalid_or_disposable_email' };\n  }\n  if (!lead.fullName || !lead.company) {\n    return { valid: false, lead: null, rejectionReason: 'missing_required_field' };\n  }\n  if (!isValidPhone(lead.phone)) {\n    return { valid: false, lead: null, rejectionReason: 'invalid_phone' };\n  }\n\n  return { valid: true, lead, rejectionReason: null };\n};",
              "packageJson": "{}"
