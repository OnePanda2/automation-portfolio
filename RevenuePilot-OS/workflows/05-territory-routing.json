              "sourceCode": {
                "code": "// Adapted from repo design: original mapped condition_field 'location' to a\n// Location field; our CRM has Country instead, so 'location' reads Country.\nfunction getFieldValue(record, fieldName) {\n  const map = {\n    company_size: () => Number(record.fields?.['Company Size']) || 0,\n    location: () => (record.fields?.Country ?? '').toLowerCase(),\n  };\n  return map[fieldName] ? map[fieldName]() : null;\n}\n\nfunction ruleMatches(rule, record) {\n  const value = getFieldValue(record, rule.condition_field);\n  if (value === null) return false;\n\n  switch (rule.condition_op) {\n    case 'gt':\n      return value > Number(rule.condition_value);\n    case 'equals':\n      // NOTE: the original repo code used .includes() for both 'equals' and\n      // 'contains', making them behave identically — that looked like a bug,\n      // so 'equals' does an exact match here instead.\n      return String(value).toLowerCase() === rule.condition_value.toLowerCase();\n    case 'contains':\n      return String(value).includes(rule.condition_value.toLowerCase());\n    case 'in':\n      return rule.condition_value.split(',').map(v => v.trim().toLowerCase()).includes(String(value));\n    default:\n      return false;\n  }\n}\n\nexport const code = async (inputs) => {\n  const { crmRecord, rulesResponse } = inputs;\n  const rawRules = rulesResponse?.body?.records || [];\n\n  const rules = rawRules.map(r => ({\n    ruleOrder: r.fields['Rule Order'],\n    condition_field: r.fields['Condition Field'],\n    condition_op: r.fields['Condition Op'],\n    condition_value: r.fields['Condition Value'],\n    territory: r.fields['Territory'],\n    rep_pool: r.fields['Rep Pool'],\n  }));\n\n  const sortedRules = [...rules].sort((a, b) => a.ruleOrder - b.ruleOrder);\n\n  for (const rule of sortedRules) {\n    if (ruleMatches(rule, crmRecord)) {\n      return {\n        recordId: crmRecord.id,\n        territory: rule.territory,\n        repPool: rule.rep_pool,\n        matchedRule: `${rule.condition_field} ${rule.condition_op} ${rule.condition_value}`,\n      };\n    }\n  }\n\n  // No rule matched — default fallback, nothing goes unrouted.\n  return {\n    recordId: crmRecord.id,\n    territory: 'unassigned',\n    repPool: 'sdr_pool',\n    matchedRule: null,\n  };\n};",
                "packageJson": "{}"
